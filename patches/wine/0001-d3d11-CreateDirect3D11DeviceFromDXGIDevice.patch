From 37a77b6e22fa1231a6fb6acf5a77c428b5e07832 Mon Sep 17 00:00:00 2001
From: DipCrai <95180035+DipCrai@users.noreply.github.com>
Date: Sun, 31 May 2026 15:17:27 +0300
Subject: [PATCH 1/2] d3d11: Implement CreateDirect3D11DeviceFromDXGIDevice

Implement the WinRT interop function CreateDirect3D11DeviceFromDXGIDevice,
which wraps an IDXGIDevice as an IInspectable implementing
IDirect3DDxgiInterfaceAccess. This is needed by applications like
Adobe CameraRaw that use this API for D3D11-D3D12 interop.

The returned object supports QueryInterface for:
- IUnknown
- IInspectable
- IDirect3DDxgiInterfaceAccess
- IAgileObject
- Any interface supported by the underlying IDXGIDevice (e.g., ID3D11Device)

Based on the Windows SDK windows.graphics.directx.direct3d11.interop.h API.
---
 dlls/d3d11/d3d11.spec   |   1 +
 dlls/d3d11/d3d11_main.c | 197 ++++++++++++++++++++++++++++++++++++++++
 2 files changed, 198 insertions(+)

diff --git a/dlls/d3d11/d3d11.spec b/dlls/d3d11/d3d11.spec
index bb755e2..cdc071f 100644
--- a/dlls/d3d11/d3d11.spec
+++ b/dlls/d3d11/d3d11.spec
@@ -1,4 +1,5 @@
 @ stdcall D3D11CoreCreateDevice(ptr ptr long ptr long ptr)
+@ stdcall CreateDirect3D11DeviceFromDXGIDevice(ptr ptr)
 @ stub D3D11CoreCreateLayeredDevice
 @ stub D3D11CoreGetLayeredDeviceSize
 @ stdcall D3D11CoreRegisterLayers()
diff --git a/dlls/d3d11/d3d11_main.c b/dlls/d3d11/d3d11_main.c
index 7598631..9376053 100644
--- a/dlls/d3d11/d3d11_main.c
+++ b/dlls/d3d11/d3d11_main.c
@@ -23,6 +23,9 @@
 #define D3D11_INIT_GUID
 #include "d3d11_private.h"
 
+/* IInspectable, TrustLevel, HSTRING */
+#include <inspectable.h>
+
 WINE_DEFAULT_DEBUG_CHANNEL(d3d11);
 
 static const char *debug_d3d_driver_type(D3D_DRIVER_TYPE driver_type)
@@ -378,6 +381,200 @@ cleanup:
     return hr;
 }
 
+/* IDirect3DDxgiInterfaceAccess GUID */
+DEFINE_GUID(IID_IDirect3DDxgiInterfaceAccess, 0xa9b3d012, 0x3df2, 0x4ee3, 0xb8,0xd1, 0x86,0x95,0xf4,0x57,0xd3,0xc1);
+
+/* IDirect3DDxgiInterfaceAccess interface definition (not in mingw-w64 headers) */
+typedef struct IDirect3DDxgiInterfaceAccessVtbl IDirect3DDxgiInterfaceAccessVtbl;
+
+typedef struct IDirect3DDxgiInterfaceAccess
+{
+    const IDirect3DDxgiInterfaceAccessVtbl *lpVtbl;
+} IDirect3DDxgiInterfaceAccess;
+
+struct IDirect3DDxgiInterfaceAccessVtbl
+{
+    HRESULT (STDMETHODCALLTYPE *QueryInterface)(IDirect3DDxgiInterfaceAccess *, REFIID, void **);
+    ULONG   (STDMETHODCALLTYPE *AddRef)(IDirect3DDxgiInterfaceAccess *);
+    ULONG   (STDMETHODCALLTYPE *Release)(IDirect3DDxgiInterfaceAccess *);
+    HRESULT (STDMETHODCALLTYPE *GetInterface)(IDirect3DDxgiInterfaceAccess *, REFIID, void **);
+};
+
+struct d3d11_dxgi_device
+{
+    IInspectable IInspectable_iface;
+    IDirect3DDxgiInterfaceAccess IDirect3DDxgiInterfaceAccess_iface;
+    LONG refcount;
+    IDXGIDevice *dxgi_device;
+};
+
+static inline struct d3d11_dxgi_device *impl_from_IInspectable(IInspectable *iface)
+{
+    return CONTAINING_RECORD(iface, struct d3d11_dxgi_device, IInspectable_iface);
+}
+
+static inline struct d3d11_dxgi_device *impl_from_IDirect3DDxgiInterfaceAccess(
+        IDirect3DDxgiInterfaceAccess *iface)
+{
+    return CONTAINING_RECORD(iface, struct d3d11_dxgi_device, IDirect3DDxgiInterfaceAccess_iface);
+}
+
+static HRESULT STDMETHODCALLTYPE d3d11_dxgi_device_QueryInterface(IInspectable *iface,
+        REFIID riid, void **obj)
+{
+    struct d3d11_dxgi_device *device = impl_from_IInspectable(iface);
+
+    if (!obj) return E_INVALIDARG;
+    *obj = NULL;
+
+    if (IsEqualIID(riid, &IID_IUnknown) ||
+        IsEqualIID(riid, &IID_IInspectable))
+    {
+        *obj = &device->IInspectable_iface;
+    }
+    else if (IsEqualIID(riid, &IID_IDirect3DDxgiInterfaceAccess))
+    {
+        *obj = &device->IDirect3DDxgiInterfaceAccess_iface;
+    }
+    else if (IsEqualIID(riid, &IID_IAgileObject))
+    {
+        *obj = &device->IInspectable_iface;
+    }
+    else if (device->dxgi_device)
+    {
+        return IDXGIDevice_QueryInterface(device->dxgi_device, riid, obj);
+    }
+    else
+    {
+        return E_NOINTERFACE;
+    }
+
+    IUnknown_AddRef((IUnknown *)*obj);
+    return S_OK;
+}
+
+static ULONG STDMETHODCALLTYPE d3d11_dxgi_device_AddRef(IInspectable *iface)
+{
+    struct d3d11_dxgi_device *device = impl_from_IInspectable(iface);
+    return InterlockedIncrement(&device->refcount);
+}
+
+static ULONG STDMETHODCALLTYPE d3d11_dxgi_device_Release(IInspectable *iface)
+{
+    struct d3d11_dxgi_device *device = impl_from_IInspectable(iface);
+    ULONG refcount = InterlockedDecrement(&device->refcount);
+
+    if (!refcount)
+    {
+        if (device->dxgi_device) IDXGIDevice_Release(device->dxgi_device);
+        free(device);
+    }
+
+    return refcount;
+}
+
+static HRESULT STDMETHODCALLTYPE d3d11_dxgi_device_GetIids(IInspectable *iface,
+        ULONG *iid_count, IID **iids)
+{
+    if (!iid_count || !iids) return E_INVALIDARG;
+    *iid_count = 0;
+    *iids = NULL;
+    return S_OK;
+}
+
+static HRESULT STDMETHODCALLTYPE d3d11_dxgi_device_GetRuntimeClassName(
+        IInspectable *iface, HSTRING *class_name)
+{
+    if (class_name) *class_name = NULL;
+    return E_NOTIMPL;
+}
+
+static HRESULT STDMETHODCALLTYPE d3d11_dxgi_device_GetTrustLevel(
+        IInspectable *iface, TrustLevel *trust_level)
+{
+    if (!trust_level) return E_POINTER;
+    *trust_level = BaseTrust;
+    return S_OK;
+}
+
+static const IInspectableVtbl d3d11_dxgi_device_inspectable_vtbl =
+{
+    d3d11_dxgi_device_QueryInterface,
+    d3d11_dxgi_device_AddRef,
+    d3d11_dxgi_device_Release,
+    d3d11_dxgi_device_GetIids,
+    d3d11_dxgi_device_GetRuntimeClassName,
+    d3d11_dxgi_device_GetTrustLevel,
+};
+
+static HRESULT STDMETHODCALLTYPE d3d11_dxgi_device_interop_QueryInterface(
+        IDirect3DDxgiInterfaceAccess *iface, REFIID riid, void **obj)
+{
+    struct d3d11_dxgi_device *device = impl_from_IDirect3DDxgiInterfaceAccess(iface);
+    return IInspectable_QueryInterface(&device->IInspectable_iface, riid, obj);
+}
+
+static ULONG STDMETHODCALLTYPE d3d11_dxgi_device_interop_AddRef(
+        IDirect3DDxgiInterfaceAccess *iface)
+{
+    struct d3d11_dxgi_device *device = impl_from_IDirect3DDxgiInterfaceAccess(iface);
+    return IInspectable_AddRef(&device->IInspectable_iface);
+}
+
+static ULONG STDMETHODCALLTYPE d3d11_dxgi_device_interop_Release(
+        IDirect3DDxgiInterfaceAccess *iface)
+{
+    struct d3d11_dxgi_device *device = impl_from_IDirect3DDxgiInterfaceAccess(iface);
+    return IInspectable_Release(&device->IInspectable_iface);
+}
+
+static HRESULT STDMETHODCALLTYPE d3d11_dxgi_device_interop_GetInterface(
+        IDirect3DDxgiInterfaceAccess *iface, REFIID iid, void **obj)
+{
+    struct d3d11_dxgi_device *device = impl_from_IDirect3DDxgiInterfaceAccess(iface);
+
+    if (!obj) return E_INVALIDARG;
+    *obj = NULL;
+
+    if (!device->dxgi_device) return E_FAIL;
+
+    return IDXGIDevice_QueryInterface(device->dxgi_device, iid, obj);
+}
+
+static const IDirect3DDxgiInterfaceAccessVtbl d3d11_dxgi_device_interop_vtbl =
+{
+    d3d11_dxgi_device_interop_QueryInterface,
+    d3d11_dxgi_device_interop_AddRef,
+    d3d11_dxgi_device_interop_Release,
+    d3d11_dxgi_device_interop_GetInterface,
+};
+
+HRESULT WINAPI CreateDirect3D11DeviceFromDXGIDevice(IDXGIDevice *dxgi_device,
+        IInspectable **graphics_device)
+{
+    struct d3d11_dxgi_device *device;
+
+    TRACE("dxgi_device %p, graphics_device %p\n", dxgi_device, graphics_device);
+
+    if (!dxgi_device || !graphics_device) return E_INVALIDARG;
+
+    if (!(device = calloc(1, sizeof(*device))))
+        return E_OUTOFMEMORY;
+
+    device->IInspectable_iface.lpVtbl = &d3d11_dxgi_device_inspectable_vtbl;
+    device->IDirect3DDxgiInterfaceAccess_iface.lpVtbl = &d3d11_dxgi_device_interop_vtbl;
+    device->refcount = 1;
+    IDXGIDevice_AddRef(dxgi_device);
+    device->dxgi_device = dxgi_device;
+
+    *graphics_device = &device->IInspectable_iface;
+
+    TRACE("Created Direct3D device wrapper %p\n", device);
+
+    return S_OK;
+}
+
+
 HRESULT WINAPI D3D11On12CreateDevice(IUnknown *device, UINT flags,
         const D3D_FEATURE_LEVEL *feature_levels, UINT feature_level_count,
         IUnknown * const *queues, UINT queue_count, UINT node_mask,
-- 
